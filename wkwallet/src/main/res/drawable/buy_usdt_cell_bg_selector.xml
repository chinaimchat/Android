<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/buy_usdt_cell_selected_bg" />
            <stroke android:width="1dp" android:color="@color/buy_usdt_cell_selected_stroke" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/buy_usdt_card" />
            <stroke android:width="1dp" android:color="@color/buy_usdt_cell_stroke" />
            <corners android:radius="6dp" />
        </shape>
    </item>
</selector>
