<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/recharge_page_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

    <include layout="@layout/wk_title_bar_layout" />

    <ScrollView
        android:id="@+id/rechargePageScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/recharge_page_pad_h"
            android:paddingTop="@dimen/recharge_page_pad_top"
            android:paddingBottom="@dimen/recharge_page_pad_bottom">

            <!-- 加载失败 / 无渠道 -->
            <LinearLayout
                android:id="@+id/rechargeEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="@dimen/recharge_empty_pad_top"
                android:paddingBottom="@dimen/recharge_empty_pad_bottom"
                android:visibility="visible">

                <TextView
                    android:id="@+id/rechargeEmptyMessageTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:lineSpacingExtra="4dp"
                    android:text="@string/wallet_recharge_loading_config"
                    android:textColor="@color/recharge_text_sub"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/rechargeRetryTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_button_primary"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="9dp"
                    android:text="@string/wallet_recharge_tap_retry"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- 区块 B：U 币（置顶） -->
            <LinearLayout
                android:id="@+id/blockUCoin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/recharge_u_block_bottom_pad"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="@dimen/recharge_section_title_margin_bottom"
                    android:text="@string/wallet_recharge_block_ucoin"
                    android:textColor="@color/recharge_text_sub"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/uCoinMethodCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/recharge_card_bg"
                    android:elevation="2dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/uCoinMethodBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/recharge_method_pad_h"
                        android:paddingVertical="@dimen/recharge_method_pad_v">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/wallet_ucoin_channel"
                            android:textColor="@color/recharge_text_sub"
                            android:textSize="@dimen/recharge_method_label_text" />

                        <TextView
                            android:id="@+id/uCoinMethodValueTv"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:gravity="end|center_vertical"
                            android:maxLines="2"
                            android:textColor="@color/recharge_text_main"
                            android:textSize="@dimen/recharge_method_value_text" />

                        <ImageView
                            android:id="@+id/uCoinMethodChevron"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="6dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_recharge_chevron_end" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/recharge_card_bg"
                    android:elevation="1.5dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/recharge_card_pad_h"
                    android:paddingVertical="@dimen/recharge_card_pad_v">

                    <TextView
                        android:id="@+id/uCoinAddressLabelTv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/recharge_text_sub"
                        android:textSize="12sp" />

                    <ImageView
                        android:id="@+id/uCoinQrIv"
                        android:layout_width="168dp"
                        android:layout_height="168dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="10dp"
                        android:background="@android:color/white"
                        android:contentDescription="@string/recharge_sheet_qr_desc"
                        android:padding="4dp"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:id="@+id/uCoinAddressTv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="3dp"
                        android:textColor="@color/recharge_text_main"
                        android:textIsSelectable="true"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/uCoinSaveQrLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/recharge_sheet_action_btn_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_recharge_save" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/recharge_sheet_save"
                                android:textColor="@color/recharge_sheet_title"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/uCoinCopyAddressLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/recharge_sheet_action_btn_bg"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingVertical="8dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_recharge_copy" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/recharge_sheet_copy"
                                android:textColor="@color/recharge_sheet_title"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/recharge_card_bg"
                    android:elevation="1.5dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/recharge_card_pad_h"
                    android:paddingTop="@dimen/recharge_card_pad_v"
                    android:paddingBottom="@dimen/recharge_card_pad_v">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wallet_ucoin_recharge_amount"
                        android:textColor="@color/recharge_text_sub"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/recharge_amount_row_margin_top"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingBottom="2dp"
                            android:text="$"
                            android:textColor="@color/recharge_text_main"
                            android:textSize="@dimen/recharge_amount_symbol_text"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/uCoinAmountEt"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="0.00"
                            android:importantForAutofill="no"
                            android:inputType="numberDecimal"
                            android:paddingStart="4dp"
                            android:paddingBottom="0dp"
                            android:textColor="@color/recharge_text_main"
                            android:textColorHint="@color/recharge_hint"
                            android:textSize="@dimen/recharge_amount_input_text"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/recharge_divider_margin_top"
                        android:background="@color/recharge_divider" />

                    <TextView
                        android:id="@+id/uCoinEstimateTv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/recharge_text_sub"
                        android:textSize="11sp"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/customerRowB"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/recharge_card_bg"
                    android:elevation="0.5dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/recharge_method_pad_h"
                    android:paddingVertical="12dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/wallet_recharge_customer_title"
                            android:textColor="@color/recharge_text_sub"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/customerNameBTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/recharge_text_main"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/customerDescBTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/recharge_text_sub"
                            android:textSize="11sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_recharge_confirm"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="@string/wallet_contact"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 区块 A：微信 / 支付宝（在 U 币下方） -->
            <LinearLayout
                android:id="@+id/blockWxAli"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/recharge_block_gap"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="@dimen/recharge_section_title_margin_bottom"
                    android:text="@string/wallet_recharge_block_wx_alipay"
                    android:textColor="@color/recharge_text_sub"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/wxMethodCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/recharge_card_bg"
                    android:elevation="2dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/wxMethodBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/recharge_method_pad_h"
                        android:paddingVertical="@dimen/recharge_method_pad_v">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/wallet_recharge_method"
                            android:textColor="@color/recharge_text_sub"
                            android:textSize="@dimen/recharge_method_label_text" />

                        <TextView
                            android:id="@+id/wxMethodValueTv"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:gravity="end|center_vertical"
                            android:maxLines="2"
                            android:textColor="@color/recharge_text_main"
                            android:textSize="@dimen/recharge_method_value_text" />

                        <ImageView
                            android:id="@+id/wxMethodChevron"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="6dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_recharge_chevron_end" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/recharge_card_bg"
                    android:elevation="1.5dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/recharge_card_pad_h"
                    android:paddingTop="@dimen/recharge_card_pad_v"
                    android:paddingBottom="@dimen/recharge_card_pad_v">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wallet_recharge_amount"
                        android:textColor="@color/recharge_text_sub"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/recharge_amount_row_margin_top"
                        android:gravity="bottom"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingBottom="2dp"
                            android:text="¥"
                            android:textColor="@color/recharge_text_main"
                            android:textSize="@dimen/recharge_amount_symbol_text"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/amountEt"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="0.00"
                            android:importantForAutofill="no"
                            android:inputType="numberDecimal"
                            android:paddingStart="4dp"
                            android:paddingBottom="0dp"
                            android:textColor="@color/recharge_text_main"
                            android:textColorHint="@color/recharge_hint"
                            android:textSize="@dimen/recharge_amount_input_text"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="@dimen/recharge_divider_margin_top"
                        android:background="@color/recharge_divider" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/customerRowA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/recharge_card_bg"
                    android:elevation="0.5dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/recharge_method_pad_h"
                    android:paddingVertical="12dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/wallet_recharge_customer_title"
                            android:textColor="@color/recharge_text_sub"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/customerNameATv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/recharge_text_main"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/customerDescATv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/recharge_text_sub"
                            android:textSize="11sp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_recharge_confirm"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="@string/wallet_contact"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/rechargeBtn"
        android:layout_width="match_parent"
        android:layout_height="@dimen/recharge_btn_height"
        android:layout_marginHorizontal="@dimen/recharge_btn_margin_h"
        android:layout_marginTop="@dimen/recharge_btn_margin_top"
        android:layout_marginBottom="@dimen/recharge_btn_margin_bottom"
        android:background="@drawable/bg_recharge_confirm"
        android:gravity="center"
        android:minHeight="@dimen/recharge_btn_height"
        android:text="@string/wallet_confirm_recharge"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/rechargeFloatingCsBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/buy_usdt_cs_fab_margin_bottom"
        android:clickable="true"
        android:contentDescription="@string/buy_usdt_contact_cs"
        android:focusable="true"
        app:cardBackgroundColor="@color/buy_usdt_cs_fab_glass"
        app:cardCornerRadius="@dimen/buy_usdt_cs_fab_radius"
        app:cardElevation="@dimen/buy_usdt_cs_fab_elevation"
        app:rippleColor="@color/buy_usdt_cs_fab_ripple"
        app:strokeColor="@color/buy_usdt_cs_fab_glass_stroke"
        app:strokeWidth="1dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:duplicateParentState="true"
            android:letterSpacing="0"
            android:paddingHorizontal="@dimen/buy_usdt_cs_fab_pad_h"
            android:paddingVertical="@dimen/buy_usdt_cs_fab_pad_v"
            android:text="@string/buy_usdt_contact_cs"
            android:textColor="@color/buy_usdt_cs_fab_text"
            android:textSize="11sp" />
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
