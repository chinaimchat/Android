<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/homeColor"
    android:orientation="vertical">

    <include layout="@layout/wk_title_bar_layout" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/redpacketTypeTabLayout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/white"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/red"
        app:tabIndicatorFullWidth="true"
        app:tabIndicatorHeight="2dp"
        app:tabMaxWidth="0dp"
        app:tabMode="fixed"
        app:tabRippleColor="#20000000"
        app:tabSelectedTextColor="@color/red"
        app:tabTextAppearance="@style/TextAppearance.AppCompat.Body1"
        app:tabTextColor="@color/color999" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_white_card_round"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp">

        <!-- 红包个数 + 其正下方「本群共 N 人」 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/countLayout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:text="@string/redpacket_count"
                    android:textColor="@color/color999"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/countEt"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:gravity="end|center_vertical"
                    android:hint="@string/redpacket_count_hint_fill"
                    android:inputType="number"
                    android:textColor="@color/colorDark"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/count_unit"
                    android:textColor="@color/colorDark"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/countLimitHintTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="96dp"
                android:paddingTop="2dp"
                android:paddingEnd="0dp"
                android:paddingBottom="8dp"
                android:textColor="@color/color999"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#10000000" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/amountTypeBadgeTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_redpacket_amount_badge_orange"
                android:gravity="center"
                android:minWidth="22dp"
                android:minHeight="22dp"
                android:paddingHorizontal="4dp"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/amountLabelTv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/redpacket_amount"
                android:textColor="@color/color999"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/amountEt"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@null"
                android:gravity="end|center_vertical"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:minWidth="72dp"
                android:textColor="@color/colorDark"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="@string/yuan"
                android:textColor="@color/colorDark"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#10000000" />

        <LinearLayout
            android:id="@+id/exclusiveMemberLayout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:text="@string/redpacket_exclusive_to"
                android:textColor="@color/color999"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/exclusiveMemberTv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:hint="@string/redpacket_select_member"
                android:textColor="@color/colorDark"
                android:textSize="15sp" />

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="6dp"
                android:alpha="0.3"
                android:rotation="180"
                android:src="@mipmap/ic_ab_back" />
        </LinearLayout>

        <View
            android:id="@+id/exclusiveDivider"
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#10000000"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/remarkEt"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/redpacket_remark_hint"
                android:inputType="text"
                android:maxLength="30"
                android:textColor="@color/colorDark"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/remarkEditHintIv"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="8dp"
                android:contentDescription="@string/redpacket_remark_hint"
                android:src="@drawable/ic_pencil_edit_gray" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/totalAmountTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="28dp"
        android:text="¥ 0.00"
        android:textColor="#E8553A"
        android:textSize="40sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/sendBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_send_redpacket_btn"
        android:gravity="center"
        android:text="@string/wallet_send_redpacket_btn"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/redpacketRefundDisclaimerTv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:text="@string/redpacket_refund_disclaimer_24h"
        android:textColor="@color/color999"
        android:textSize="12sp" />
</LinearLayout>
