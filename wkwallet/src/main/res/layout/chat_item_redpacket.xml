<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/redpacketLayout"
    android:layout_width="252dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_redpacket_bubble"
    android:elevation="2dp"
    android:orientation="vertical"
    android:outlineProvider="background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/iconIv"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/ic_redpacket_icon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/remarkTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp"
                android:maxLines="2"
                android:text="@string/redpacket_remark"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/redpacketDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="12dp"
        android:alpha="0.35"
        android:background="#FFFFFF" />

    <TextView
        android:id="@+id/typeTv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alpha="0.88"
        android:paddingHorizontal="16dp"
        android:paddingTop="9dp"
        android:paddingBottom="11dp"
        android:text="@string/redpacket"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />
</LinearLayout>
