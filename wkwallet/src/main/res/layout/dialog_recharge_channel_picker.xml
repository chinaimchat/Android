<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/recharge_picker_panel_bg"
    android:orientation="vertical"
    android:paddingBottom="12dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/recharge_picker_handle" />

    <TextView
        android:id="@+id/pickerTitleTv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:paddingHorizontal="20dp"
        android:text="@string/wallet_select_channel"
        android:textColor="@color/recharge_text_main"
        android:textSize="17sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pickerRv"
        android:layout_width="match_parent"
        android:layout_height="288dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:overScrollMode="ifContentScrolls"
        android:paddingBottom="4dp"
        android:scrollbars="vertical" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:background="@color/recharge_divider" />

    <TextView
        android:id="@+id/pickerCancelTv"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="?android:attr/selectableItemBackground"
        android:gravity="center"
        android:text="@string/cancel"
        android:textColor="@color/recharge_text_sub"
        android:textSize="16sp" />
</LinearLayout>
