<?xml version="1.0" encoding="utf-8"?>
<!-- FrameLayout 叠底「联系客服」与买币页一致，Scroll 区加大底部留白避免被遮挡 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/recharge_sheet_page_bg">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/rechargeSheetNestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/buy_usdt_scroll_bottom_pad">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/recharge_sheet_bar_bg"
            android:paddingHorizontal="8dp">

            <TextView
                android:id="@+id/sheetDoneTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="@string/recharge_sheet_done"
                android:textColor="@color/recharge_sheet_action_blue"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/wallet_recharge"
                android:textColor="@color/recharge_sheet_title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/sheetOrdersTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:text="@string/buy_usdt_orders"
                android:textColor="@color/recharge_sheet_action_blue"
                android:textSize="15sp" />
        </RelativeLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/recharge_sheet_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/recharge_sheet_card_stroke"
            app:strokeWidth="0.5dp">

            <LinearLayout
                android:id="@+id/chainSelectorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/recharge_usdt_circle"
                    android:gravity="center"
                    android:text="₮"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/chainNameTv"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:textColor="@color/recharge_sheet_chain_blue"
                    android:textSize="15sp"
                    tools:text="USDT-TRC20" />

                <ImageView
                    android:id="@+id/chainChevronIv"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_recharge_chevron_right" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/recharge_sheet_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/recharge_sheet_card_stroke"
            app:strokeWidth="0.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <ImageView
                    android:id="@+id/depositQrIv"
                    android:layout_width="@dimen/recharge_sheet_qr_size"
                    android:layout_height="@dimen/recharge_sheet_qr_size"
                    android:layout_gravity="center_horizontal"
                    android:background="@android:color/white"
                    android:contentDescription="@string/recharge_sheet_qr_desc"
                    android:padding="4dp"
                    android:scaleType="fitCenter"
                    tools:src="@android:color/darker_gray" />

                <TextView
                    android:id="@+id/depositAddressTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/recharge_sheet_address_bg"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="1dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/recharge_sheet_address_text"
                    android:textIsSelectable="true"
                    android:textSize="12sp"
                    tools:text="TYTyr87r6MpzNCk…" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/saveQrLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/recharge_sheet_action_btn_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingVertical="8dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_recharge_save" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/recharge_sheet_save"
                            android:textColor="@color/recharge_sheet_title"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/copyAddressLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/recharge_sheet_action_btn_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingVertical="8dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_recharge_copy" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/recharge_sheet_copy"
                            android:textColor="@color/recharge_sheet_title"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/sheetAmountCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="14dp"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/recharge_sheet_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/recharge_sheet_card_stroke"
            app:strokeWidth="0.5dp"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/recharge_sheet_amount_label"
                    android:textColor="@color/recharge_sheet_min_label"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.15" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/sheetAmountSymbolTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingBottom="2dp"
                        android:text="$"
                        android:textColor="@color/recharge_sheet_title"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/sheetAmountEt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="0.00"
                        android:importantForAutofill="no"
                        android:inputType="numberDecimal"
                        android:paddingStart="6dp"
                        android:textColor="@color/recharge_sheet_title"
                        android:textColorHint="@color/recharge_sheet_min_value"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/sheetAmountRangeTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/recharge_sheet_min_value"
                    android:textSize="12sp"
                    android:visibility="gone"
                    tools:text="单笔最低 1，最高 10000"
                    tools:visibility="visible" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:background="@color/recharge_sheet_pick_divider" />

                <TextView
                    android:id="@+id/sheetEstimateTv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/recharge_sheet_min_value"
                    android:textSize="12sp"
                    android:visibility="gone"
                    tools:text="预计到账约 ¥7.20（仅供参考，以审核结果为准）"
                    tools:visibility="visible" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sheetConfirmRechargeBtn"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:minHeight="42dp"
                    android:text="@string/recharge_sheet_confirm_recharge"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    app:backgroundTint="@color/recharge_sheet_action_blue"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/openFullRechargeTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:background="?attr/selectableItemBackground"
            android:padding="8dp"
            android:text="@string/recharge_sheet_open_full"
            android:textColor="@color/recharge_sheet_action_blue"
            android:textSize="14sp"
            android:visibility="gone"
            tools:visibility="visible" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/recharge_sheet_footer_warning"
            android:textColor="@color/recharge_sheet_footer"
            android:textSize="11sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/rechargeSheetContactCsBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/buy_usdt_cs_fab_margin_bottom"
        android:clickable="true"
        android:contentDescription="@string/buy_usdt_contact_cs"
        android:focusable="true"
        app:cardBackgroundColor="@color/buy_usdt_cs_fab_glass"
        app:cardCornerRadius="@dimen/buy_usdt_cs_fab_radius"
        app:cardElevation="@dimen/buy_usdt_cs_fab_elevation"
        app:rippleColor="@color/buy_usdt_cs_fab_ripple"
        app:strokeColor="@color/buy_usdt_cs_fab_glass_stroke"
        app:strokeWidth="1dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:duplicateParentState="true"
            android:letterSpacing="0"
            android:paddingHorizontal="@dimen/buy_usdt_cs_fab_pad_h"
            android:paddingVertical="@dimen/buy_usdt_cs_fab_pad_v"
            android:text="@string/buy_usdt_contact_cs"
            android:textColor="@color/buy_usdt_cs_fab_text"
            android:textSize="11sp" />
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
